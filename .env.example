# VIDRA Environment Configuration

# =========================
# LLM API Keys (Choose ONE)
# =========================

# Option 1: OpenAI (Paid - GPT-4o-mini ~$0.15/1M tokens)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: Groq (FREE - Fast Llama 3.1 70B)
# Sign up at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# =========================
# Redis Configuration
# =========================
REDIS_URL=redis://localhost:6379/0

# =========================
# FastAPI Configuration
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# =========================
# Storage Configuration
# =========================
# For MVP: Using local file storage
OUTPUT_DIR=./outputs
# For Production: Use cloud storage
# CLOUD_STORAGE_PROVIDER=r2  # r2, s3, gcs
# CLOUD_STORAGE_BUCKET=vidra-outputs
# CLOUD_STORAGE_ACCESS_KEY=your-access-key
# CLOUD_STORAGE_SECRET_KEY=your-secret-key

# =========================
# Model Configuration
# =========================

# Image Generation Model (choose one)
IMAGE_MODEL=stabilityai/stable-diffusion-3-medium-diffusers
# Alternative: black-forest-labs/FLUX.1-dev (better quality, slower)
# Alternative: stabilityai/stable-diffusion-xl-base-1.0 (faster)

# Animation Model
ANIMATION_MODEL=stabilityai/stable-video-diffusion-img2vid-xt

# TTS Model
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Music Generation Model
MUSIC_MODEL=facebook/musicgen-medium
# Alternative: facebook/musicgen-small (faster)
# Alternative: facebook/musicgen-large (better quality)

# =========================
# Generation Parameters
# =========================

# Image generation
IMAGE_INFERENCE_STEPS=28
IMAGE_GUIDANCE_SCALE=7.5
IMAGE_WIDTH=1024
IMAGE_HEIGHT=576

# Video generation
VIDEO_FPS=7
VIDEO_NUM_FRAMES=25  # ~3.5 seconds at 7fps
VIDEO_MOTION_BUCKET_ID=127

# Audio generation
MUSIC_DURATION=10  # seconds per clip
TTS_LANGUAGE=en

# =========================
# Performance Settings
# =========================
ENABLE_GPU_OPTIMIZATION=true
ENABLE_MODEL_OFFLOAD=true
TORCH_DTYPE=float16  # float16 or float32
